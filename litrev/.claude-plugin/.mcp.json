{
  "mcpServers": {
    "litrev-mcp": {
      "command": "uv",
      "args": ["run", "--directory", "${CLAUDE_PLUGIN_ROOT}/mcp", "litrev-mcp"],
      "env": {
        "S2_API_KEY": "${S2_API_KEY}",
        "NCBI_API_KEY": "${NCBI_API_KEY}",
        "LITREV_EMAIL": "${LITREV_EMAIL}"
      },
      "timeout": 120
    }
  }
}
